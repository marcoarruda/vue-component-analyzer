{
  "name": "vue-component-analyzer",
  "version": "0.0.1",
  "displayName": "Vue Component Analyzer",
  "description": "Analyze Vue 3 components and visualize component complexity.",
  "publisher": "MarcoArruda",
  "icon": "media/logo.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:vue",
    "workspaceContains:**/*.vue"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vueComponentAnalyzer.toggleTreeDisplayMode",
        "title": "Vue Analyzer: Toggle Component View Mode",
        "icon": "$(list-tree)"
      },
      {
        "command": "vueComponentAnalyzer.switchToFolderTreeDisplayMode",
        "title": "Vue Analyzer: Switch Component View To Folders",
        "icon": "$(list-tree)"
      },
      {
        "command": "vueComponentAnalyzer.switchToListTreeDisplayMode",
        "title": "Vue Analyzer: Switch Component View To List",
        "icon": "$(list-flat)"
      },
      {
        "command": "vueComponentAnalyzer.setListSortMode",
        "title": "Vue Analyzer: Set Component List Sort",
        "icon": "$(sort-precedence)"
      },
      {
        "command": "vueComponentAnalyzer.showComplexity",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/complexity.svg",
          "dark": "media/complexity-dark.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showProjectGraph",
        "title": "Vue Analyzer: Show Project Graph",
        "icon": "$(graph)"
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.empty",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-empty.svg",
          "dark": "media/file-badges/analysis-empty.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs.svg",
          "dark": "media/file-badges/analysis-inputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.stores",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-stores.svg",
          "dark": "media/file-badges/analysis-stores.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.injects",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-injects.svg",
          "dark": "media/file-badges/analysis-injects.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.outputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-outputs.svg",
          "dark": "media/file-badges/analysis-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsStores",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-stores.svg",
          "dark": "media/file-badges/analysis-inputs-stores.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsInjects",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-injects.svg",
          "dark": "media/file-badges/analysis-inputs-injects.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-outputs.svg",
          "dark": "media/file-badges/analysis-inputs-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.storesInjects",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-stores-injects.svg",
          "dark": "media/file-badges/analysis-stores-injects.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.storesOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-stores-outputs.svg",
          "dark": "media/file-badges/analysis-stores-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.injectsOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-injects-outputs.svg",
          "dark": "media/file-badges/analysis-injects-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjects",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-stores-injects.svg",
          "dark": "media/file-badges/analysis-inputs-stores-injects.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsStoresOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-stores-outputs.svg",
          "dark": "media/file-badges/analysis-inputs-stores-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsInjectsOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-injects-outputs.svg",
          "dark": "media/file-badges/analysis-inputs-injects-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.storesInjectsOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-stores-injects-outputs.svg",
          "dark": "media/file-badges/analysis-stores-injects-outputs.svg"
        }
      },
      {
        "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjectsOutputs",
        "title": "Vue Analyzer: Show Complexity",
        "icon": {
          "light": "media/file-badges/analysis-inputs-stores-injects-outputs.svg",
          "dark": "media/file-badges/analysis-inputs-stores-injects-outputs.svg"
        }
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vueComponentAnalyzer.showComplexity.empty",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.stores",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.injects",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.outputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStores",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsInjects",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesInjects",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.injectsOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjects",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsInjectsOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesInjectsOutputs",
          "when": "false"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjectsOutputs",
          "when": "false"
        }
      ],
      "editor/title": [
        {
          "command": "vueComponentAnalyzer.showComplexity.empty",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-empty'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.stores",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-stores'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.injects",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-injects'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.outputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStores",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-stores'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsInjects",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-injects'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesInjects",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-stores-injects'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-stores-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.injectsOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-injects-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjects",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-stores-injects'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-stores-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsInjectsOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-injects-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.storesInjectsOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-stores-injects-outputs'",
          "group": "navigation"
        },
        {
          "command": "vueComponentAnalyzer.showComplexity.inputsStoresInjectsOutputs",
          "when": "resourceExtname == .vue && vueComponentAnalyzer.topbarBadge == 'analysis-inputs-stores-injects-outputs'",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "vueComponentAnalyzer.switchToFolderTreeDisplayMode",
          "when": "view == vueComponentAnalyzer.components && vueComponentAnalyzer.componentsViewMode == list",
          "group": "navigation@1"
        },
        {
          "command": "vueComponentAnalyzer.switchToListTreeDisplayMode",
          "when": "view == vueComponentAnalyzer.components && vueComponentAnalyzer.componentsViewMode == folders",
          "group": "navigation@1"
        },
        {
          "command": "vueComponentAnalyzer.setListSortMode",
          "when": "view == vueComponentAnalyzer.components && config.vueComponentAnalyzer.components.viewMode == list",
          "group": "navigation@2"
        },
        {
          "command": "vueComponentAnalyzer.showProjectGraph",
          "when": "view == vueComponentAnalyzer.components",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Vue Component Analyzer",
      "properties": {
        "vueComponentAnalyzer.components.viewMode": {
          "type": "string",
          "enum": ["list", "folders"],
          "default": "folders",
          "description": "Choose whether the Vue Components view is shown as one flat list or grouped by directory structure."
        },
        "vueComponentAnalyzer.components.listSortBy": {
          "type": "string",
          "enum": ["path", "inputs", "reactivity", "outputs", "injects", "provides", "stores"],
          "default": "path",
          "description": "Choose how the flat Vue Components list is sorted. Metric sorts show the highest counts first."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "vueComponentAnalyzer",
          "title": "Vue Analyzer",
          "icon": "media/logo-sidebar.svg"
        }
      ]
    },
    "views": {
      "vueComponentAnalyzer": [
        {
          "id": "vueComponentAnalyzer.components",
          "name": "Vue Components",
          "icon": "media/logo-sidebar.svg"
        }
      ]
    }
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --packages=external --platform=node --format=cjs --target=node20 --external:vscode --outfile=dist/extension.js",
    "watch": "npm run build -- --watch",
    "package": "vsce package",
    "set:version": "node -e \"const fs=require('fs'); const pkgPath='package.json'; const version=process.env.RELEASE_VERSION || process.env.npm_config_version; if (!version) { console.error('Missing version. Use RELEASE_VERSION=<semver> npm run set:version'); process.exit(1); } const pkg=JSON.parse(fs.readFileSync(pkgPath,'utf8')); pkg.version=version; fs.writeFileSync(pkgPath, JSON.stringify(pkg, null, 2) + '\\n'); console.log('package.json version set to', version);\""
  },
  "devDependencies": {
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^24.0.0",
    "@types/vscode": "^1.100.0",
    "esbuild": "^0.25.0",
    "vsce": "^2.15.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/marcoarruda/vue-component-analyzer.git"
  },
  "dependencies": {
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "@vue/compiler-dom": "^3.5.32",
    "@vue/compiler-sfc": "^3.5.32",
    "typescript": "^5.8.0"
  }
}
